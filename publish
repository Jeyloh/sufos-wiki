#!/bin/bash
set -e

REPO="$(cd "$(dirname "$0")" && pwd)"
SUFOS="/Users/jorgen.lybeck.hansen@m10s.io/Library/Mobile Documents/iCloud~md~obsidian/Documents/Personal/DnD/Characters/sufos"
VAULT="/Users/jorgen.lybeck.hansen@m10s.io/Library/Mobile Documents/iCloud~md~obsidian/Documents/Personal"

echo "→ Syncing notes and images from Obsidian vault..."
rsync -a --delete \
  --exclude="CLAUDE.md" \
  --exclude="Drafts/" \
  --exclude=".obsidian/" \
  "$SUFOS/" \
  "$REPO/content/"

echo "→ Copying pasted images from vault root..."
python3 - <<EOF
import re, os, shutil, glob

content_dir = "$REPO/content"
vault = "$VAULT"

refs = set()
for path in glob.glob(content_dir + "/**/*.md", recursive=True):
    text = open(path).read()
    refs.update(re.findall(r'!\[\[(Pasted image[^\]]+)\]\]', text))

for img in sorted(refs):
    src = os.path.join(vault, img)
    if os.path.isfile(src):
        # Place alongside the md file that references it
        for md in glob.glob(content_dir + "/**/*.md", recursive=True):
            if img in open(md).read():
                dest_dir = os.path.join(os.path.dirname(md), "Assets", "images")
                os.makedirs(dest_dir, exist_ok=True)
                shutil.copy2(src, os.path.join(dest_dir, img))
                print(f"  copied: {img}")
                break
EOF

cd "$REPO"

if git diff --quiet && git diff --cached --quiet; then
  echo "→ No changes to publish."
  exit 0
fi

echo "→ Committing..."
git add -A
git commit -m "publish $(date '+%Y-%m-%d %H:%M')"

echo "→ Pushing..."
git push

echo "✓ Done. GitHub Actions will deploy in ~1 minute."
