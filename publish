#!/bin/bash
set -e

REPO="$(cd "$(dirname "$0")" && pwd)"
SUFOS="/Users/jorgen.lybeck.hansen@m10s.io/Library/Mobile Documents/iCloud~md~obsidian/Documents/Personal/DnD/Characters/sufos"
VAULT="/Users/jorgen.lybeck.hansen@m10s.io/Library/Mobile Documents/iCloud~md~obsidian/Documents/Personal"

echo "→ Syncing notes from Obsidian vault..."
rsync -a --delete \
  --exclude="CLAUDE.md" \
  --exclude="Drafts/" \
  --exclude=".obsidian/" \
  --exclude="Assets/" \
  "$SUFOS/" \
  "$REPO/content/"

echo "→ Syncing images..."
mkdir -p "$REPO/content/Assets/images"

# Images stored within the sufos vault folder
rsync -a "$SUFOS/Assets/" "$REPO/content/Assets/"

# Pasted images stored at vault root (Obsidian default attachment location)
python3 - <<EOF
import re, os, shutil, glob

content_dir = "$REPO/content"
vault = "$VAULT"
dest_dir = "$REPO/content/Assets/images"

refs = set()
for path in glob.glob(content_dir + "/**/*.md", recursive=True):
    text = open(path).read()
    refs.update(re.findall(r'!\[\[(Pasted image[^\]]+)\]\]', text))

for img in sorted(refs):
    src = os.path.join(vault, img)
    dst = os.path.join(dest_dir, img)
    if os.path.isfile(src):
        shutil.copy2(src, dst)
        print(f"  copied: {img}")
EOF

cd "$REPO"

if git diff --quiet && git diff --cached --quiet; then
  echo "→ No changes to publish."
  exit 0
fi

echo "→ Committing..."
git add -A
git commit -m "publish $(date '+%Y-%m-%d %H:%M')"

echo "→ Pushing..."
git push

echo "✓ Done. GitHub Actions will deploy in ~1 minute."
